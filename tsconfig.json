{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",

    /* Core Safety */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Code Cleanliness Flags */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true
  },
  /* Include both production source code and the root test directories */
  "include": [
    "src/**/*",
    "tests/**/*",
    "integration/**/*",
    "integration",
    "tests"
  ],
  /* Exclude the test folders from the build (not included in /dist) */
  "exclude": ["node_modules", "dist", "tests/**/*", "integration/**/*"]
}
